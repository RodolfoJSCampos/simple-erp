rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isString(value) {
      return value is string;
    }

    function isNonEmptyString(value) {
      return isString(value) && value.size() > 0;
    }

    function isOptionalString(value) {
      return value == null || isString(value);
    }

    function isInt(value) {
      return value is int;
    }

    function isNumber(value) {
      return value is int || value is float;
    }

    function validProductData(data) {
      return data.keys().hasOnly([
          'sku',
          'description',
          'imageUrl',
          'stock',
          'brand',
          'costHistory',
          'expirationDate'
        ]) &&
        isNonEmptyString(data.sku) &&
        isNonEmptyString(data.description) &&
        isString(data.imageUrl) &&
        isInt(data.stock) && data.stock >= 0 &&
        isNonEmptyString(data.brand) &&
        data.costHistory is list &&
        data.costHistory.size() <= 2000 &&
        isOptionalString(data.expirationDate);
    }

    function validOrderData(data) {
      return data.keys().hasOnly([
          'id',
          'origin',
          'originIconUrl',
          'registeredAt',
          'items'
        ]) &&
        isNonEmptyString(data.id) &&
        isNonEmptyString(data.origin) &&
        isOptionalString(data.originIconUrl) &&
        isNonEmptyString(data.registeredAt) &&
        data.items is list &&
        data.items.size() > 0 &&
        data.items.size() <= 200;
    }

    function validBrandData(data) {
      return data.keys().hasOnly(['name']) && isNonEmptyString(data.name);
    }

    function validOriginData(data) {
      return data.keys().hasOnly(['name', 'iconUrl']) &&
        isNonEmptyString(data.name) &&
        isOptionalString(data.iconUrl);
    }

    match /products/{sku} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && validProductData(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /orders/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && validOrderData(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /brands/{name} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && validBrandData(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /origins/{name} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && validOriginData(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
